{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BenchmarkTask",
  "type": "object",
  "required": ["task_id", "task_type", "lean_task", "difficulty", "domain_tags"],
  "properties": {
    "task_id": {"type": "string"},
    "task_type": {
      "type": "string",
      "enum": ["formal_only", "formalization", "repair", "subgoal_completion", "lemma_growth"]
    },
    "lean_task": {
      "type": "object",
      "required": ["task_id", "imports", "namespace", "statement"],
      "properties": {
        "task_id": {"type": "string"},
        "imports": {"type": "array", "items": {"type": "string"}},
        "namespace": {"type": "string"},
        "statement": {"type": "string"},
        "allowed_sorry": {"type": "boolean"},
        "tags": {"type": "array", "items": {"type": "string"}},
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "expected_patterns": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "difficulty": {"type": "string"},
    "domain_tags": {"type": "array", "items": {"type": "string"}},
    "split": {"type": "string", "enum": ["train", "dev", "test"]},
    "natural_language": {"type": ["string", "null"]},
    "proof_state": {"type": ["string", "null"]},
    "expected_premises": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
