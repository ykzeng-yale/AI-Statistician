{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VdVWPrimitiveEmpiricalSemantics",
  "type": "object",
  "required": [
    "report_id",
    "source",
    "markdown_root",
    "depends_on_artifacts",
    "source_anchors",
    "primitive_count",
    "status_counts",
    "layer_counts",
    "design_ready_primitives",
    "blocked_primitives",
    "planned_theorem_hole_seed_count",
    "planned_theorem_hole_seed_ids",
    "primitives",
    "acceptance_gates",
    "next_actions",
    "notes"
  ],
  "properties": {
    "report_id": {"type": "string"},
    "source": {"type": "string"},
    "markdown_root": {"type": "string"},
    "depends_on_artifacts": {"type": "array", "items": {"type": "string"}},
    "source_anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["anchor_id", "label", "markdown_anchor", "purpose"],
        "properties": {
          "anchor_id": {"type": "string"},
          "label": {"type": "string"},
          "markdown_anchor": {
            "type": "object",
            "required": ["root", "segment", "line_start", "line_end"],
            "properties": {
              "root": {"type": "string"},
              "segment": {"type": "string"},
              "line_start": {"type": "integer"},
              "line_end": {"type": "integer"}
            },
            "additionalProperties": false
          },
          "purpose": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "primitive_count": {"type": "integer"},
    "status_counts": {"type": "object", "additionalProperties": {"type": "integer"}},
    "layer_counts": {"type": "object", "additionalProperties": {"type": "integer"}},
    "design_ready_primitives": {"type": "array", "items": {"type": "string"}},
    "blocked_primitives": {"type": "array", "items": {"type": "string"}},
    "planned_theorem_hole_seed_count": {"type": "integer"},
    "planned_theorem_hole_seed_ids": {"type": "array", "items": {"type": "string"}},
    "primitives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "primitive_id",
          "layer",
          "status",
          "source_anchor_ids",
          "target_lean_module",
          "target_lean_signatures",
          "current_lean_handoffs",
          "theorem_card_gaps",
          "existing_benchmark_task_ids",
          "missing_existing_benchmark_task_ids",
          "planned_theorem_hole_seed_ids",
          "validation_hooks",
          "semantic_risks",
          "promotion_gate",
          "human_review_required"
        ],
        "properties": {
          "primitive_id": {"type": "string"},
          "layer": {"type": "string"},
          "status": {"type": "string"},
          "source_anchor_ids": {"type": "array", "items": {"type": "string"}},
          "target_lean_module": {"type": "string"},
          "target_lean_signatures": {"type": "array", "items": {"type": "string"}},
          "current_lean_handoffs": {"type": "array", "items": {"type": "string"}},
          "theorem_card_gaps": {"type": "array", "items": {"type": "string"}},
          "existing_benchmark_task_ids": {"type": "array", "items": {"type": "string"}},
          "missing_existing_benchmark_task_ids": {"type": "array", "items": {"type": "string"}},
          "planned_theorem_hole_seed_ids": {"type": "array", "items": {"type": "string"}},
          "validation_hooks": {"type": "array", "items": {"type": "string"}},
          "semantic_risks": {"type": "array", "items": {"type": "string"}},
          "promotion_gate": {"type": "string"},
          "human_review_required": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "acceptance_gates": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
