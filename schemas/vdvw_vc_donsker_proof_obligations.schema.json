{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VdVWVCDonskerProofObligations",
  "type": "object",
  "required": [
    "report_id",
    "source_inventory_ids",
    "source",
    "markdown_root",
    "source_anchors",
    "obligation_count",
    "status_counts",
    "track_counts",
    "blocked_obligations",
    "obligations",
    "acceptance_gates",
    "next_actions",
    "notes"
  ],
  "properties": {
    "report_id": {"type": "string"},
    "source_inventory_ids": {"type": "array", "items": {"type": "string"}},
    "source": {"type": "string"},
    "markdown_root": {"type": "string"},
    "source_anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["anchor_id", "label", "markdown_anchor", "purpose"],
        "properties": {
          "anchor_id": {"type": "string"},
          "label": {"type": "string"},
          "markdown_anchor": {
            "type": "object",
            "required": ["root", "segment", "line_start", "line_end"],
            "properties": {
              "root": {"type": "string"},
              "segment": {"type": "string"},
              "line_start": {"type": "integer"},
              "line_end": {"type": "integer"}
            },
            "additionalProperties": false
          },
          "purpose": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "obligation_count": {"type": "integer"},
    "status_counts": {"type": "object", "additionalProperties": {"type": "integer"}},
    "track_counts": {"type": "object", "additionalProperties": {"type": "integer"}},
    "blocked_obligations": {"type": "array", "items": {"type": "string"}},
    "obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "obligation_id",
          "source_label",
          "track",
          "status",
          "target_lean_names",
          "formal_goal",
          "required_primitives",
          "proof_obligations",
          "current_lean_handoffs",
          "benchmark_task_ids",
          "missing_benchmark_task_ids",
          "validation_hooks",
          "semantic_risks",
          "promotion_gate",
          "human_review_required"
        ],
        "properties": {
          "obligation_id": {"type": "string"},
          "source_label": {"type": "string"},
          "track": {"type": "string"},
          "status": {"type": "string"},
          "target_lean_names": {"type": "array", "items": {"type": "string"}},
          "formal_goal": {"type": "string"},
          "required_primitives": {"type": "array", "items": {"type": "string"}},
          "proof_obligations": {"type": "array", "items": {"type": "string"}},
          "current_lean_handoffs": {"type": "array", "items": {"type": "string"}},
          "benchmark_task_ids": {"type": "array", "items": {"type": "string"}},
          "missing_benchmark_task_ids": {"type": "array", "items": {"type": "string"}},
          "validation_hooks": {"type": "array", "items": {"type": "string"}},
          "semantic_risks": {"type": "array", "items": {"type": "string"}},
          "promotion_gate": {"type": "string"},
          "human_review_required": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "acceptance_gates": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
